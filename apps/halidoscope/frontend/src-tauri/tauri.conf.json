{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Halidoscope",
  "version": "0.1.0",
  "identifier": "com.halide.halidescope",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Halidoscope",
        "width": 1512,
        "height": 982
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "args": [
        {
          "name": "trace",
          "short": "t",
          "takesValue": true,
          "description": "Path to .hltrace file to load on startup"
        }
      ]
    }
  }
}
